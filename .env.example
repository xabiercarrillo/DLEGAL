# ═══════════════════════════════════════════════════════════════
#  XLegal v2.0.0 — Variables de Entorno
#  Copiar a .env y completar con credenciales reales
#  Paraguay 🇵🇾 | Guaraníes (₲) | IVA 10%
# ═══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
APP_NAME=XLegal
APP_VERSION=2.0.0
ENVIRONMENT=production    # development | production
DEBUG=false
APP_URL=https://app.xlegal.com.py
CORS_ORIGINS=https://app.xlegal.com.py,https://xlegal.com.py

# ── Seguridad ─────────────────────────────────────────────────
SECRET_KEY=cambiar-por-clave-aleatoria-de-64-chars-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Base de Datos ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://xlegal:xlegal_secret_2024@db:5432/xlegal
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Super Administrador ───────────────────────────────────────
FIRST_SUPERUSER_EMAIL=xabiercarrillo@gmail.com
FIRST_SUPERUSER_PASSWORD=XLegal

# ═══════════════════════════════════════════════════════════════
#  1️⃣  FIRMA ELECTRÓNICA
# ═══════════════════════════════════════════════════════════════

# PandaDoc — https://app.pandadoc.com/a/#/apikeys
# Plan free: 5 documentos/mes con auditoría legal
PANDADOC_API_KEY=

# DocuSign — https://developers.docusign.com
# Requiere OAuth; configurar en Integraciones → DocuSign → Conectar
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_USER_ID=
DOCUSIGN_PRIVATE_KEY=

# SignNow — https://app.signnow.com/webapp/settings/api-dashboard
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════
#  2️⃣  PAGOS Y FACTURACIÓN
# ═══════════════════════════════════════════════════════════════

# Bancard 🇵🇾 — https://developers.bancard.com.py
# Procesador local de Paraguay. Solicitar credenciales en bancard.com.py
BANCARD_PRIVATE_KEY=
BANCARD_PUBLIC_KEY=
# Producción: https://vpos.infonet.com.py
# Staging: https://vpos.infonet.com.py:8888
BANCARD_BASE_URL=https://vpos.infonet.com.py

# Mercado Pago — https://www.mercadopago.com.py/developers
MERCADOPAGO_ACCESS_TOKEN=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal — https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════
#  3️⃣  COMUNICACIÓN Y NOTIFICACIONES
# ═══════════════════════════════════════════════════════════════

# Resend — https://resend.com (email principal)
RESEND_API_KEY=re_...

# SendGrid — https://app.sendgrid.com/settings/api_keys (email fallback)
SENDGRID_API_KEY=

# Mailgun — https://app.mailgun.com/mg/dashboard (email fallback)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Twilio — https://console.twilio.com
# WhatsApp Business: obtener número aprobado por Meta
TWILIO_ACCOUNT_SID=ACxxx...
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1xxx...

# Vonage/Nexmo — https://dashboard.nexmo.com (SMS alternativo)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Pusher — https://dashboard.pusher.com (notificaciones realtime)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# ═══════════════════════════════════════════════════════════════
#  4️⃣  INTELIGENCIA ARTIFICIAL
# ═══════════════════════════════════════════════════════════════

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Cohere — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  5️⃣  ALMACENAMIENTO DE DOCUMENTOS
# ═══════════════════════════════════════════════════════════════

# Proveedor: local | s3 | r2 | gcs
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/media
MAX_UPLOAD_MB=50

# AWS S3 — https://console.aws.amazon.com/iam
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=xlegal-docs
AWS_REGION=us-east-1

# Cloudflare R2 — sin costo de egreso, ideal para latencia en PY
# https://developers.cloudflare.com/r2
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=xlegal-docs

# Google Cloud Storage
GCS_BUCKET=
GCS_CREDENTIALS_JSON=

# ═══════════════════════════════════════════════════════════════
#  7️⃣  AGENDA Y REUNIONES
# ═══════════════════════════════════════════════════════════════

# Google Calendar / Google Meet OAuth
# https://console.cloud.google.com → APIs → Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.xlegal.com.py/api/v1/integrations/oauth/google-calendar/callback

# Zoom — https://marketplace.zoom.us/develop/create
# Usar Server-to-Server OAuth app
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════
#  8️⃣  DOCUMENTOS Y PDFs
# ═══════════════════════════════════════════════════════════════

# WeasyPrint instalado localmente (sin costo, máxima privacidad)
# pip install weasyprint  — ya incluido en requirements

# DocRaptor — https://docraptor.com/users/sign_up (plan free: 5/mes)
# DOCRAPTOR_API_KEY=

# PDFShift — https://pdfshift.io
# PDFSHIFT_API_KEY=

# CloudConvert (Word → PDF) — https://cloudconvert.com/api
# CLOUDCONVERT_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  9️⃣  MAPAS Y GEOLOCALIZACIÓN
# ═══════════════════════════════════════════════════════════════

# Google Maps — https://developers.google.com/maps
# Activar: Maps JavaScript API, Geocoding API, Directions API
GOOGLE_MAPS_API_KEY=

# Mapbox — https://account.mapbox.com/access-tokens
MAPBOX_TOKEN=

# ═══════════════════════════════════════════════════════════════
#  🔟  AUTOMATIZACIÓN — WEBHOOKS OUTBOUND
# ═══════════════════════════════════════════════════════════════
# Configurar desde la app: Integraciones → Webhooks → Nuevo
# Compatible: Zapier, Make (Integromat), n8n, cualquier URL HTTP

# ── PayU (pagos alternativos) ─────────────────────────────────────
PAYU_API_KEY=
PAYU_MERCHANT_ID=
